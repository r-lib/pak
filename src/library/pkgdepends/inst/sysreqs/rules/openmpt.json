{
  "patterns": ["\\bopenmpt\\b"],
  "dependencies": [
    {
      "packages": ["libopenmpt-dev", "portaudio19-dev"],
      "constraints": [
        {
          "os": "linux",
          "distribution": "ubuntu"
        },
        {
          "os": "linux",
          "distribution": "debian"
        }
      ]
    },
    {
      "packages": ["libopenmpt-devel", "portaudio-devel"],
      "constraints": [
        {
          "os": "linux",
          "distribution": "opensuse"
        },
        {
          "os": "linux",
          "distribution": "fedora"
        }
      ]
    },
    {
      "packages": ["libopenmpt-devel", "portaudio-devel"],
      "pre_install": [
        { "command": "yum install -y epel-release" }
      ],
      "constraints": [
        {
          "os": "linux",
          "distribution": "centos"
        },
        {
          "os": "linux",
          "distribution": "rockylinux"
        }
      ]
    },
    {
      "packages": ["libopenmpt-devel", "portaudio-devel"],
      "pre_install": [
        {
          "command": "rpm -q epel-release || yum install -y https://dl.fedoraproject.org/pub/epel/epel-release-latest-$(rpm -E %rhel).noarch.rpm"
        }
      ],
      "constraints": [
        {
          "os": "linux",
          "distribution": "redhat",
          "versions": ["8", "9", "10"]
        }
      ]
    },
    {
      "packages": ["libopenmpt-dev", "portaudio-dev"],
      "constraints": [
        {
          "os": "linux",
          "distribution": "alpine",
          "versions": [ "3.18", "3.19", "3.20", "3.21", "edge" ]
        }
      ]
    }
  ]
}
