{
  "patterns": ["\\blibgrpc\\+\\+"],
  "dependencies": [
    {
      "packages": ["libgrpc++-dev"],
      "constraints": [
        {
          "os": "linux",
          "distribution": "ubuntu"
        },
        {
          "os": "linux",
          "distribution": "debian"
        }
      ]
    },
    {
      "packages": ["grpc-devel", "pkgconf"],
      "constraints": [
        {
          "os": "linux",
          "distribution": "fedora"
        }
      ]
    },
    {
      "pre_install": [
        { "command": "yum install -y epel-release" },
        { "command": "dnf install -y dnf-plugins-core" },
        { "command": "dnf config-manager --set-enabled crb" }
      ],
      "packages": ["grpc-devel", "pkgconf"],
      "constraints": [
        {
          "os": "linux",
          "distribution": "rockylinux",
          "versions": ["9", "10"]
        }
      ]
    },
    {
      "packages": ["grpc-devel"],
      "constraints": [
        {
          "os": "linux",
          "distribution": "opensuse"
        },
        {
          "os": "linux",
          "distribution": "sle"
        }
      ]
    },
    {
      "packages": ["grpc-devel", "pkgconf"],
      "pre_install": [
        { "command": "dnf install -y https://dl.fedoraproject.org/pub/epel/epel-release-latest-8.noarch.rpm && dnf copr enable -y ceph/grpc" }
      ],
      "constraints": [
        {
          "os": "linux",
          "distribution": "redhat",
          "versions": ["8"]
        }
      ]
    },
    {
      "packages": ["grpc-devel", "pkgconf"],
      "pre_install": [
        {
          "command": "rpm -q epel-release || yum install -y https://dl.fedoraproject.org/pub/epel/epel-release-latest-$(rpm -E %rhel).noarch.rpm"
        }
      ],
      "constraints": [
        {
          "os": "linux",
          "distribution": "redhat",
          "versions": ["9", "10"]
        }
      ]
    },
    {
      "packages": ["grpc-dev"],
      "constraints": [
        {
          "os": "linux",
          "distribution": "alpine"
        }
      ]
    }
  ]
}
