{
  "patterns": [
    "\\blibavif\\b"
  ],
  "dependencies": [
    {
      "packages": [
        "libavif-dev"
      ],
      "constraints": [
        {
          "os": "linux",
          "distribution": "debian"
        },
        {
          "os": "linux",
          "distribution": "ubuntu"
        },
        {
          "os": "linux",
          "distribution": "alpine"
        }
      ]
    },
    {
      "packages": [
        "libavif-devel"
      ],
      "constraints": [
        {
          "os": "linux",
          "distribution": "opensuse"
        },
        {
          "os": "linux",
          "distribution": "fedora"
        }
      ]
    },
    {
      "packages": [
        "libavif-devel"
      ],
      "pre_install": [
        {
          "command": "dnf install -y epel-release"
        }
      ],
      "constraints": [
        {
          "os": "linux",
          "distribution": "rockylinux"
        }
      ]
    },
    {
      "packages": [
        "libavif-devel"
      ],
      "pre_install": [
        {
          "command": "dnf install -y https://dl.fedoraproject.org/pub/epel/epel-release-latest-$(rpm -E %rhel).noarch.rpm"
        }
      ],
      "constraints": [
        {
          "os": "linux",
          "distribution": "redhat",
          "versions": [
            "8",
            "9",
            "10"
          ]
        }
      ]
    }
  ]
}
